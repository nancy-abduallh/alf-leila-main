// tsconfig.json
{
  "files": [],
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@contracts/*": [
        "./contracts/*"
      ],
      "@db/*": [
        "./db/*"
      ]
    }
  },
  "include": [
    "server",
    "api",
    "contracts",
    "db"
  ]
}